{
	"manifest_version": 3,
	"name": "kib",
	"description": "Save any webpage to your knowledge base",
	"version": "0.6.0",
	"permissions": ["activeTab", "scripting", "tabs", "storage"],
	"host_permissions": ["http://localhost:4747/*"],
	"action": {
		"default_popup": "popup.html",
		"default_title": "Save to kib"
	},
	"background": {
		"service_worker": "background.js"
	},
	"icons": {
		"16": "icons/icon-16.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	}
}
